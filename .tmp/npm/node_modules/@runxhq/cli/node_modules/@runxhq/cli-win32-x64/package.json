{
  "name": "@runxhq/cli-win32-x64",
  "version": "0.6.1",
  "description": "Runx CLI - native governed runtime for agent skills, tools, graphs, and packets. (win32-x64)",
  "private": false,
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/runxhq/runx",
  "bugs": {
    "url": "https://github.com/runxhq/runx/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runxhq/runx.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "os": [
    "win32"
  ],
  "cpu": [
    "x64"
  ],
  "runx": {
    "nativePackage": {
      "schema": "runx.rust_cli_native_package.v1",
      "selectorPackage": "@runxhq/cli",
      "platform": "win32-x64",
      "binary": "bin/runx.exe"
    }
  },
  "files": [
    "LICENSE",
    "bin",
    "native/checksums.json",
    "native/signatures.json"
  ]
}
