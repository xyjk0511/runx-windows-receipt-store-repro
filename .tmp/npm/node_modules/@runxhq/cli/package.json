{
  "name": "@runxhq/cli",
  "version": "0.6.1",
  "description": "Runx CLI - native governed runtime for agent skills, tools, graphs, and packets.",
  "private": false,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/runxhq/runx",
  "bugs": {
    "url": "https://github.com/runxhq/runx/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runxhq/runx.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "runx": "./bin/runx"
  },
  "runx": {
    "nativeSelector": {
      "schema": "runx.rust_cli_selector_topology.v1",
      "supportedPlatforms": [
        "darwin-arm64",
        "darwin-x64",
        "linux-arm64",
        "linux-x64",
        "win32-x64"
      ],
      "nativePackagePattern": "@runxhq/cli-${platform}"
    }
  },
  "optionalDependencies": {
    "@runxhq/cli-darwin-arm64": "0.6.1",
    "@runxhq/cli-darwin-x64": "0.6.1",
    "@runxhq/cli-linux-arm64": "0.6.1",
    "@runxhq/cli-linux-x64": "0.6.1",
    "@runxhq/cli-win32-x64": "0.6.1"
  },
  "files": [
    "LICENSE",
    "bin/runx",
    "native/supported-platforms.json"
  ]
}
